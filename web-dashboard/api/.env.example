# Anthropic API Key (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Upstash Redis URL (get from console.upstash.com)
# Format: redis://:password@hostname:port
UPSTASH_REDIS_URL=redis://:password@hostname:port

# Flask Settings
FLASK_ENV=production
PORT=8000

# CORS Settings
CORS_ORIGINS=*
